# Optional environment variables for the real-data ingestion pipeline.
# Unset values cause the ingestors to fall back to bundled fixtures.

# Path to a local copy of the ONS Postcode Directory CSV (unzipped).
# Download from: https://geoportal.statistics.gov.uk/search?q=ONSPD
# Example: ONSPD_CSV_PATH=/data/ONSPD/ONSPD_FEB_2026_UK.csv
ONSPD_CSV_PATH=

# Path to an HM Land Registry Price Paid Data CSV (trailing N months).
# Download from: https://www.gov.uk/government/statistical-data-sets/price-paid-data-downloads
# Example: PPD_CSV_PATH=/data/PPD/pp-2026-rolling.csv
PPD_CSV_PATH=

# Path to a data.police.uk street-level crime CSV (concatenation of trailing
# 12 months of *-street.csv files across the forces covering each region).
# Download from: https://data.police.uk/data/
# Example: POLICE_UK_CSV_PATH=/data/police-uk/street-2025-05-to-2026-04.csv
POLICE_UK_CSV_PATH=

# Path to an Ofcom Connected Nations postcode-level fixed broadband CSV.
# Download from:
#   https://www.ofcom.org.uk/research-and-data/multi-sector-research/infrastructure-research/connected-nations
# Example: OFCOM_BROADBAND_CSV_PATH=/data/ofcom/connected-nations-2025-postcode.csv
OFCOM_BROADBAND_CSV_PATH=
