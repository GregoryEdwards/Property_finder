# Optional environment variables for the real-data ingestion pipeline.
# Unset values cause the ingestors to fall back to bundled fixtures.

# Path to a local copy of the ONS Postcode Directory CSV (unzipped).
# Download from: https://geoportal.statistics.gov.uk/search?q=ONSPD
# Example: ONSPD_CSV_PATH=/data/ONSPD/ONSPD_FEB_2026_UK.csv
ONSPD_CSV_PATH=

# Path to an HM Land Registry Price Paid Data CSV (trailing N months).
# Download from: https://www.gov.uk/government/statistical-data-sets/price-paid-data-downloads
# Example: PPD_CSV_PATH=/data/PPD/pp-2026-rolling.csv
PPD_CSV_PATH=
