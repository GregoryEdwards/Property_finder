{
  "name": "homesite",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "HomeSite — GIS Interactive Property Finder (Phase 1, UK / Greater London).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "npm run seed:london && npm run seed:wm",
    "seed:london": "tsx scripts/generate-london-seed.ts && tsx scripts/generate-london-listings.ts",
    "seed:wm": "tsx scripts/generate-west-midlands-seed.ts && tsx scripts/generate-west-midlands-listings.ts",
    "seed:cells:london": "tsx scripts/generate-london-seed.ts",
    "seed:cells:wm": "tsx scripts/generate-west-midlands-seed.ts",
    "seed:listings:london": "tsx scripts/generate-london-listings.ts",
    "seed:listings:wm": "tsx scripts/generate-west-midlands-listings.ts",
    "ingest:median-price": "tsx scripts/ingest/median-price.ts",
    "ingest:crime-rate": "tsx scripts/ingest/crime-rate.ts",
    "build-seed:london": "tsx scripts/build-region-seed.ts --region=greater-london",
    "build-seed:wm": "tsx scripts/build-region-seed.ts --region=west-midlands",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@deck.gl/core": "^9.0.33",
    "@deck.gl/geo-layers": "^9.0.33",
    "@deck.gl/layers": "^9.0.33",
    "@deck.gl/react": "^9.0.33",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.59.20",
    "@turf/turf": "^7.1.0",
    "clsx": "^2.1.1",
    "h3-js": "^4.1.0",
    "lucide-react": "^0.460.0",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^7.1.7",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  }
}
